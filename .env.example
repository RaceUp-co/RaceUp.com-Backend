# ===========================================
# Variables d'environnement - Backend RaceUp
# ===========================================
# Ces variables sont des secrets et doivent être configurées via Wrangler :
# wrangler secret put JWT_SECRET
# wrangler secret put GOOGLE_CLIENT_ID
# etc.
#
# Ne jamais commiter les vraies valeurs !

# ---------------------
# Authentification JWT
# ---------------------
# Secret pour signer les JWT (min 32 caractères aléatoires)
# Générer avec : openssl rand -base64 32
JWT_SECRET=

# ---------------------
# OAuth - Google
# ---------------------
# Client ID depuis Google Cloud Console
GOOGLE_CLIENT_ID=

# ---------------------
# OAuth - Apple
# ---------------------
# Service ID depuis Apple Developer
APPLE_CLIENT_ID=

# ---------------------
# KV Namespace (Consentements)
# ---------------------
# Créer le namespace avec : wrangler kv namespace create "consent_store"
# Puis copier l'ID généré dans wrangler.toml
# KV_CONSENT_ID=

# ---------------------
# Configuration dans wrangler.toml
# ---------------------
# Les variables suivantes sont déjà dans wrangler.toml [vars] :
# - ENVIRONMENT = "production"
# - ACCESS_TOKEN_EXPIRY = "900" (15 minutes en secondes)
# - REFRESH_TOKEN_EXPIRY = "604800" (7 jours en secondes)
